{
  "expo": {
    "name": "PagaAI",
    "slug": "paga-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "scheme": "pagaai",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "icon": "./assets/images/icon.png",
    "newArchEnabled": false,
    "updates": {
      "enabled": false
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pagaai.mobile",
      "associatedDomains": [
        "applinks:pagai.com"
      ]
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "googleServicesFile": "./google-services.json",
      "package": "com.pagaai.mobile",
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "pagaai",
              "host": "reset-password"
            },
            {
              "scheme": "https",
              "host": "pagai.com",
              "pathPrefix": "/reset-password"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "plugins": [
      "expo-router",
      "@react-native-community/datetimepicker",
      "expo-sharing"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "70835f7e-976c-4b5e-8f64-03f69e5ff995"
      }
    }
  }
}
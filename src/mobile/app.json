{
    "expo": {
        "name": "PagaAI",
        "slug": "paga-ai",
        "version": "1.0.0",
        "orientation": "portrait",
        "platforms": [ "ios", "android", "web" ],
        "scheme": "pagaai",
        "userInterfaceStyle": "automatic",
        "icon": "./assets/images/icon.png",
        "assetBundlePatterns": [ "**/*" ],
        "newArchEnabled": false,
        "ios": {
            "supportsTablet": true
        },
        "android": {
            "adaptiveIcon": {
                "foregroundImage": "./assets/images/adaptive-icon.png",
                "backgroundColor": "#ffffff"
            }
        },
        "plugins": [ "expo-router" ]
    }
}

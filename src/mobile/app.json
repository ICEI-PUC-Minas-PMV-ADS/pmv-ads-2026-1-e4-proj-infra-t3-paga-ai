{
  "expo": {
    "name": "PagaAI",
    "slug": "paga-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "scheme": "pagaai",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "icon": "./assets/images/icon.png",
    "newArchEnabled": false,
    "updates": {
      "enabled": false
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "googleServicesFile": "./google-services.json",
      "package": "com.pagaai.mobile"
    },
    "plugins": [
      "expo-router",
      "@react-native-community/datetimepicker",
      "expo-sharing"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "70835f7e-976c-4b5e-8f64-03f69e5ff995"
      }
    }
  }
}

{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "jsx": "react-jsx",
    "strict": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@components/*": ["components/*"],
      "@services/*": ["services/*"],
      "@hooks/*": ["hooks/*"],
      "@types/*": ["types/*"],
      "@constants/*": ["constants/*"],
      "@contexts/*": ["contexts/*"],
      "emprestimo": ["types/emprestimo"],
      "@/*": ["src/*"]
    }
  }
}
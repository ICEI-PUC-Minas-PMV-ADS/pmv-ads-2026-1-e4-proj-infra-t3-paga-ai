{
  "MongoDbSettings": {
    "ConnectionString": "mongodb://localhost:27017",
    "DatabaseName": "pagai"
  },
  "GatewaySettings": {
    "JwtSecret": "your-super-secret-key-change-this-in-production-must-be-at-least-32-characters-long",
    "JwtIssuer": "paga-ai-gateway",
    "JwtAudience": "paga-ai-clients",
    "JwtExpirationMinutes": 60
  },
  "RateLimiting": {
    "Enabled": true,
    "RequestsPerMinute": 100
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Ocelot": "Information"
    }
  }
}